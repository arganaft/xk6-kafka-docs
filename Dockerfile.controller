# syntax=docker/dockerfile:1.7
ARG BASE_IMAGE=pinot-base:latest
FROM ${BASE_IMAGE}

# Production defaults — переопределяются env vars при запуске
ENV PINOT_ROLE=controller \
    PINOT_HEAP_MIN=4g \
    PINOT_HEAP_MAX=4g \
    PINOT_GC_PROFILE=g1 \
    PINOT_CONFIG=/etc/pinot/controller.conf

EXPOSE 9000 8888

ENTRYPOINT ["/opt/pinot/bin/pinot-launcher.sh"]
CMD ["StartController"]
