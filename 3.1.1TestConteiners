## 5. Assertions для формата ответов

`src/test/java/com/pivotService/support/WebSocketResponseAssertions.java`

```java
package com.pivotService.support;

import com.fasterxml.jackson.databind.JsonNode;

import java.time.Instant;
import java.util.ArrayList;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatCode;

public final class WebSocketResponseAssertions {

    private WebSocketResponseAssertions() {
    }

    public static List<String> requestedFields(JsonNode request) {
        JsonNode columns = request.at("/data/columns");

        assertThat(columns.isArray())
                .as("request.data.columns should be array")
                .isTrue();

        List<String> result = new ArrayList<>();

        for (JsonNode column : columns) {
            String fieldKey = column.path("fieldKey").asText(null);

            assertThat(fieldKey)
                    .as("column.fieldKey")
                    .isNotBlank();

            result.add(fieldKey);
        }

        return result;
    }

    public static void assertConfigurationUpdatedFormat(JsonNode actual, JsonNode originalRequest) {
        assertThat(actual.path("type").asText())
                .isEqualTo("ConfigurationUpdated");

        assertThat(actual.path("success").asBoolean())
                .isTrue();

        JsonNode config = actual.get("config");

        assertThat(config)
                .as("config")
                .isNotNull();

        assertThat(config.isObject())
                .as("config should be object")
                .isTrue();

        assertNumber(config, "liveBookId");
        assertNumber(config, "startRow");
        assertNumber(config, "endRow");

        assertArray(config, "groupKeys");
        assertObject(config, "filterModel");
        assertArray(config, "sortModel");
        assertArray(config, "columns");
        assertArray(config, "rowGroupColumns");
        assertArray(config, "valueColumns");

        assertThat(config.path("pivotMode").isBoolean())
                .as("config.pivotMode should be boolean")
                .isTrue();

        assertArray(config, "pivotColumns");

        assertText(config, "requestId");
        assertText(config, "clientId");

        assertThat(config.path("requestId").asText())
                .isEqualTo(originalRequest.at("/data/requestId").asText());

        assertThat(config.path("clientId").asText())
                .isEqualTo(originalRequest.at("/data/clientId").asText());

        assertText(config, "liveBookName");

        String timestamp = actual.path("timestamp").asText(null);

        assertThat(timestamp)
                .as("timestamp")
                .isNotBlank();

        assertThatCode(() -> Instant.parse(timestamp))
                .as("timestamp should be ISO instant")
                .doesNotThrowAnyException();

        assertThat(actual.has("errorMessage"))
                .as("errorMessage field should exist")
                .isTrue();

        JsonNode errorMessage = actual.get("errorMessage");

        assertThat(errorMessage.isNull() || errorMessage.isTextual())
                .as("errorMessage should be null or string")
                .isTrue();
    }

    public static void assertReceiveDataFormat(JsonNode actual, List<String> expectedColumns) {
        assertThat(actual.path("type").asText())
                .isEqualTo("ReceiveData");

        assertThat(actual.path("success").asBoolean())
                .isTrue();

        JsonNode data = actual.get("data");

        assertThat(data)
                .as("data")
                .isNotNull();

        assertThat(data.isArray())
                .as("data should be array")
                .isTrue();

        assertThat(data.size())
                .as("data should contain at least one block")
                .isGreaterThan(0);

        for (JsonNode dataBlock : data) {
            assertText(dataBlock, "requestId");
            assertNumber(dataBlock, "totalCount");

            JsonNode rows = dataBlock.get("rows");

            assertThat(rows)
                    .as("rows")
                    .isNotNull();

            assertThat(rows.isArray())
                    .as("rows should be array")
                    .isTrue();

            assertThat(rows.size())
                    .as("rows should contain at least one row")
                    .isGreaterThan(0);

            for (JsonNode row : rows) {
                assertThat(row.isObject())
                        .as("row should be object")
                        .isTrue();

                assertThat(row.has("saved_at"))
                        .as("row should contain saved_at")
                        .isTrue();

                for (String expectedColumn : expectedColumns) {
                    assertThat(row.has(expectedColumn))
                            .as("row should contain column '%s'. Row: %s", expectedColumn, row)
                            .isTrue();
                }
            }
        }
    }

    private static void assertText(JsonNode object, String fieldName) {
        JsonNode value = object.get(fieldName);

        assertThat(value)
                .as(fieldName)
                .isNotNull();

        assertThat(value.isTextual())
                .as(fieldName + " should be text")
                .isTrue();

        assertThat(value.asText())
                .as(fieldName + " should not be blank")
                .isNotBlank();
    }

    private static void assertNumber(JsonNode object, String fieldName) {
        JsonNode value = object.get(fieldName);

        assertThat(value)
                .as(fieldName)
                .isNotNull();

        assertThat(value.isNumber())
                .as(fieldName + " should be number")
                .isTrue();
    }

    private static void assertArray(JsonNode object, String fieldName) {
        JsonNode value = object.get(fieldName);

        assertThat(value)
                .as(fieldName)
                .isNotNull();

        assertThat(value.isArray())
                .as(fieldName + " should be array")
                .isTrue();
    }

    private static void assertObject(JsonNode object, String fieldName) {
        JsonNode value = object.get(fieldName);

        assertThat(value)
                .as(fieldName)
                .isNotNull();

        assertThat(value.isObject())
                .as(fieldName + " should be object")
                .isTrue();
    }
}
